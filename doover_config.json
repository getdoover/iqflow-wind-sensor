{
    "iqflow_wind_sensor": {
        "name": "iqflow_wind_sensor",
        "display_name": "IQFlow Wind Sensor",
        "type": "DEV",
        "visibility": "PUB",
        "allow_many": true,
        "description": "Reads wind speed and direction from an IQFlow IQWS sensor over Modbus RTU.",
        "long_description": "README.md",
        "depends_on": [],
        "owner_org_key": "",
        "icon_url": "https://iqflow.io/cdn/shop/files/IQFLOW1_250x.png?v=1768631147",
        "image_name": "ghcr.io/getdoover/iqflow_wind_sensor",
        "container_registry_profile_id": 93955828574386692,
        "build_args": "--platform linux/amd64,linux/arm64",
        "config_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "",
            "title": "$default",
            "type": "object",
            "properties": {
                "sensor_name": {
                    "title": "Sensor Name",
                    "x-name": "sensor_name",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Display name for this sensor instance.",
                    "default": "Wind Sensor",
                    "x-position": 0
                },
                "variant": {
                    "enum": [
                        "combined",
                        "speed_only"
                    ],
                    "title": "Sensor Variant",
                    "x-name": "variant",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "combined = IQWS-D / SD-A (wind speed + direction). speed_only = IQWS-S (wind speed only).",
                    "default": "combined",
                    "x-position": 1
                },
                "modbus_config": {
                    "title": "Modbus Config",
                    "x-name": "modbus_config",
                    "x-hidden": false,
                    "type": "object",
                    "x-required": true,
                    "x-position": 2,
                    "properties": {
                        "bus_type": {
                            "enum": [
                                "serial",
                                "tcp"
                            ],
                            "title": "Bus Type",
                            "x-name": "bus_type",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
                            "default": "serial",
                            "x-position": 1
                        },
                        "name": {
                            "title": "Name",
                            "x-name": "name",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
                            "default": "default",
                            "x-position": 2
                        },
                        "serial_port": {
                            "title": "Serial Port",
                            "x-name": "serial_port",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
                            "default": "/dev/ttyAMA0",
                            "x-position": 3
                        },
                        "serial_baud": {
                            "title": "Serial Baud",
                            "x-name": "serial_baud",
                            "x-hidden": false,
                            "type": [
                                "integer",
                                "null"
                            ],
                            "x-required": false,
                            "default": 9600,
                            "x-position": 4
                        },
                        "serial_method": {
                            "enum": [
                                "rtu",
                                "ascii",
                                "socket",
                                "tls"
                            ],
                            "title": "Serial Method",
                            "x-name": "serial_method",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
                            "default": "rtu",
                            "x-position": 5
                        },
                        "serial_data_bits": {
                            "title": "Serial Data Bits",
                            "x-name": "serial_data_bits",
                            "x-hidden": false,
                            "type": [
                                "integer",
                                "null"
                            ],
                            "x-required": false,
                            "default": 8,
                            "x-position": 6
                        },
                        "serial_parity": {
                            "enum": [
                                "None",
                                "Even",
                                "Odd"
                            ],
                            "title": "Serial Parity",
                            "x-name": "serial_parity",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
                            "default": "None",
                            "x-position": 7
                        },
                        "serial_stop_bits": {
                            "title": "Serial Stop Bits",
                            "x-name": "serial_stop_bits",
                            "x-hidden": false,
                            "type": [
                                "integer",
                                "null"
                            ],
                            "x-required": false,
                            "default": 1,
                            "x-position": 8
                        },
                        "serial_timeout": {
                            "title": "Serial Timeout",
                            "x-name": "serial_timeout",
                            "x-hidden": false,
                            "type": [
                                "number",
                                "null"
                            ],
                            "x-required": false,
                            "default": 0.3,
                            "x-position": 9
                        },
                        "tcp_uri": {
                            "title": "TCP URI",
                            "x-name": "tcp_uri",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
                            "default": "127.0.0.1:5000",
                            "x-position": 10
                        },
                        "tcp_timeout": {
                            "title": "TCP Timeout",
                            "x-name": "tcp_timeout",
                            "x-hidden": false,
                            "type": [
                                "number",
                                "null"
                            ],
                            "x-required": false,
                            "default": 2.0,
                            "x-position": 11
                        }
                    },
                    "additionalElements": true,
                    "required": [],
                    "x-collapsible": true,
                    "x-defaultCollapsed": false
                },
                "slave_id": {
                    "title": "Slave ID",
                    "x-name": "slave_id",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Modbus unit / slave ID of the IQWS sensor (1..247).",
                    "default": 1,
                    "x-position": 3
                },
                "poll_interval_seconds": {
                    "title": "Poll Interval (seconds)",
                    "x-name": "poll_interval_seconds",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "How often to read the sensor.",
                    "default": 3,
                    "x-position": 4
                },
                "display_unit": {
                    "enum": [
                        "kmh",
                        "mps",
                        "knots"
                    ],
                    "title": "Wind Speed Unit",
                    "x-name": "display_unit",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Unit used for wind speed and gust tags/UI.",
                    "default": "kmh",
                    "x-position": 5
                },
                "gust_window_seconds": {
                    "title": "Gust Window (seconds)",
                    "x-name": "gust_window_seconds",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Rolling-window size used to compute the gust (peak) wind speed.",
                    "default": 180,
                    "x-position": 6
                },
                "no_comms_timeout_seconds": {
                    "title": "No-Comms Timeout (seconds)",
                    "x-name": "no_comms_timeout_seconds",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Clear comms_ok after this many seconds without a successful read.",
                    "default": 30,
                    "x-position": 7
                },
                "sim_app_key": {
                    "title": "Simulator App Key",
                    "x-name": "sim_app_key",
                    "x-hidden": false,
                    "format": "doover-resource-application",
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Optional. If set, read wind data from this simulator app's tags instead of the Modbus bus. Leave blank for normal operation.",
                    "default": "",
                    "x-position": 8
                }
            },
            "additionalElements": true,
            "required": [
                "modbus_config"
            ]
        },
        "ui_schema": {
            "displayString": "$config.app().APP_DISPLAY_NAME",
            "hidden": "$config.app().hidden:boolean:false:boolean:false",
            "position": "$config.app().dv_app_position:number:100",
            "icon": null,
            "colour": null,
            "defaultOpen": false,
            "type": "uiApplication",
            "name": "$config.app().APP_KEY",
            "children": {
                "wind_speed": {
                    "name": "wind_speed",
                    "type": "uiVariable",
                    "displayString": "Wind Speed",
                    "showActivity": true,
                    "position": 1,
                    "hidden": false,
                    "varType": "float",
                    "currentValue": "$tag.app().wind_speed:number:0",
                    "decPrecision": 1
                },
                "wind_gust": {
                    "name": "wind_gust",
                    "type": "uiVariable",
                    "displayString": "Wind Gust",
                    "showActivity": true,
                    "position": 2,
                    "hidden": false,
                    "varType": "float",
                    "currentValue": "$tag.app().wind_gust:number:0",
                    "decPrecision": 1
                },
                "wind_direction_degrees": {
                    "name": "wind_direction_degrees",
                    "type": "uiVariable",
                    "displayString": "Wind Direction (\u00b0)",
                    "showActivity": true,
                    "position": 3,
                    "hidden": false,
                    "varType": "float",
                    "currentValue": "$tag.app().wind_direction_degrees:number:0",
                    "decPrecision": 0
                },
                "wind_direction_compass": {
                    "name": "wind_direction_compass",
                    "type": "uiVariable",
                    "displayString": "Wind Direction",
                    "showActivity": true,
                    "position": 4,
                    "hidden": false,
                    "varType": "string",
                    "currentValue": "$tag.app().wind_direction_compass:string:\"\""
                },
                "comms_ok": {
                    "name": "comms_ok",
                    "type": "uiVariable",
                    "displayString": "Sensor Communicating",
                    "showActivity": true,
                    "position": 5,
                    "hidden": false,
                    "varType": "bool",
                    "currentValue": "$tag.app().comms_ok:boolean:false"
                }
            }
        },
        "organisation_id": null,
        "id": 171809838517475598,
        "key": null,
        "owner_org_id": null,
        "code_repo_id": null,
        "repo_branch": "main",
        "lambda_config": null,
        "banner_url": null,
        "staging_config": {},
        "build_widget_command": null,
        "export_config_command": null,
        "export_ui_command": null,
        "run_command": null,
        "lambda_arn": null
    }
}